# Active exchange (must match a key in src/exchanges/REGISTRY)
EXCHANGE=hyperliquid

# ── Hyperliquid ──────────────────────────────────────────────────────────────
HYPERLIQUID_WALLET_ADDRESS=0x...   # your wallet address (account ID)
HYPERLIQUID_PRIVATE_KEY=0x...      # private key for signing
HYPERLIQUID_BUILDER_CODE=0x...     # builder address for fee-share program

# ── TradeXYZ (HIP-3 DEX on Hyperliquid — same API, different builder code) ──
TRADEXYZ_WALLET_ADDRESS=0x...
TRADEXYZ_PRIVATE_KEY=0x...
TRADEXYZ_BUILDER_CODE=             # leave blank — builder address is public and hardcoded

# ── DreamCash (Hyperliquid-based — builder defaults to official address) ─────
DREAMCASH_WALLET_ADDRESS=0x...
DREAMCASH_PRIVATE_KEY=0x...
DREAMCASH_BUILDER_CODE=            # leave blank to use 0x4950994884602d1b6c6d96e4fe30f58205c39395

# ── Hibachi (CCXT — different API) ───────────────────────────────────────────
HIBACHI_API_KEY=
HIBACHI_ACCOUNT_ID=                # numeric account ID
HIBACHI_PRIVATE_KEY=               # 0x... for ECDSA, plain string for HMAC
